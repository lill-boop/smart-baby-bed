<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">
    
    <!-- 顶部导航栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:background="@drawable/bg_header_gradient"
        android:gravity="center_vertical"
        android:elevation="4dp">
        
        <ImageButton
            android:id="@+id/btnCloseLive"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/btn_icon_circle"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:scaleType="centerInside"
            android:padding="8dp"
            app:tint="#FFFFFF"
            android:contentDescription="关闭" />
        
        <TextView
            android:id="@+id/tvLiveTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📹 宝宝实时画面"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center" />
        
        <ImageButton
            android:id="@+id/btnRotateLive"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/btn_icon_circle"
            android:src="@android:drawable/ic_menu_rotate"
            android:scaleType="centerInside"
            android:padding="8dp"
            app:tint="#FFFFFF"
            android:contentDescription="旋转" />
    </LinearLayout>
    
    <!-- 状态指示条 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:background="#1A1A1A"
        android:gravity="center_vertical">
        
        <View
            android:id="@+id/viewLiveIndicator"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_status_dot_green" />
        
        <TextView
            android:id="@+id/tvLiveStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="连接中..."
            android:textSize="12sp"
            android:textColor="#888888"
            android:paddingStart="8dp" />
        
        <ProgressBar
            android:id="@+id/progressBarLive"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:indeterminateTint="#4CAF50"
            android:visibility="visible" />
        
        <Button
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="重连"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:visibility="gone"
            android:background="@drawable/btn_retry"
            android:paddingHorizontal="12dp" />
    </LinearLayout>
    
    <!-- 实时视频区域 - 上半部分，占更多空间 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3">
        
        <androidx.media3.ui.PlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:show_buffering="when_playing"
            app:use_controller="false"
            app:resize_mode="fit" />
        
        <!-- 标签 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="8dp"
            android:text="📹 实时画面"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:background="#88000000"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp" />
        
        <!-- 加载遮罩 -->
        <LinearLayout
            android:id="@+id/loadingOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#CC000000"
            android:visibility="gone">
            
            <ProgressBar
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:indeterminateTint="#FFFFFF" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="连接中..."
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:layout_marginTop="8dp" />
        </LinearLayout>
        
    </FrameLayout>
    

    
    <!-- 对讲区域 - 底部 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingVertical="20dp"
        android:background="#111111">

        <TextView
            android:id="@+id/tvIntercomStatusOverlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="正在收听环境音..."
            android:textColor="#AAAAAA"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnTalkOverlay"
            android:layout_width="160dp"
            android:layout_height="56dp"
            android:text="🎙️ 按住说话"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF9800"
            android:elevation="6dp"
            android:stateListAnimator="@null" />
    </LinearLayout>
    
</LinearLayout>
